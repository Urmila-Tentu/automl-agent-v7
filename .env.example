# ─── AutoML Agent Environment Variables ─────────────────────────────────────
# Copy this to .env and fill in your values before running.

# ── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=REPLACE-WITH-256-BIT-RANDOM-SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ── Training ────────────────────────────────────────────────────────────────
N_TRIALS_OPTUNA=30
CV_FOLDS=5
TEST_SIZE=0.2
RANDOM_STATE=42
ENABLE_DEEP_LEARNING=true
DL_ROW_THRESHOLD=5000
N_JOBS=-1

# ── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db

# ── Drift Detection ──────────────────────────────────────────────────────────
DRIFT_THRESHOLD=0.1
DRIFT_CHECK_INTERVAL_MINUTES=60

# ── Cloud (optional) ─────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET=my-automl-models
